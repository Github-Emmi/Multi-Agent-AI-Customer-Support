
# AI — OpenRouter (OpenAI-compatible free tier)
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3

# Intent Routing (Kaggle Factory) — "local" uses the fine-tuned classifier
# artifact (no LLM call per query); "llm" falls back to OpenRouter.
# Local mode auto-falls back to the LLM if the artifact is missing.
ROUTING_MODE=local
INTENT_MODEL_PATH=backend/models/intent_classifier
INTENT_CONFIDENCE_THRESHOLD=0.4

# Embeddings — pin device to avoid Apple-Silicon MPS shutdown segfault
EMBEDDING_DEVICE=cpu

# Ingestion — heavy RAG index build is offline (Kaggle); keep disabled in prod
ENABLE_INGESTION=false

# File Upload
MAX_UPLOAD_SIZE_MB=20
UPLOAD_DIR=uploads/

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Logging
LOG_LEVEL=INFO

# Database
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/customer_support?appName=YOUR_APP

# JWT
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Pinecone
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=techmart-kb
PINECONE_HOST=https://YOUR_INDEX.svc.YOUR_REGION.pinecone.io

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
