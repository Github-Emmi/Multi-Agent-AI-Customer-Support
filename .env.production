# =============================================================================
# TechMart Multi-Agent AI — PRODUCTION Environment Variables
# =============================================================================
# Copy this file to .env when deploying to Railway/Render.
# Set these as environment variables in Railway dashboard — never commit secrets.
# =============================================================================

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=REPLACE_WITH_PRODUCTION_KEY
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3

# ── Intent Routing (Kaggle Factory) ──────────────────────────────────────────
# Local classifier removes the per-query LLM call that caused 429 rate limits.
# The LLM is reserved for the high-value final response generation only.
ROUTING_MODE=local
INTENT_MODEL_PATH=backend/models/intent_classifier
INTENT_CONFIDENCE_THRESHOLD=0.4

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_DEVICE=cpu

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Never rebuild the index on the production server — load the Kaggle artifact.
ENABLE_INGESTION=false

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=REPLACE_WITH_MONGODB_ATLAS_URI

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Vector Store — use Pinecone in production for stateless scaling ───────────
VECTOR_STORE=pinecone
PINECONE_API_KEY=REPLACE_WITH_PINECONE_KEY
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=techmart-kb
PINECONE_HOST=REPLACE_WITH_PINECONE_HOST_URL

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_GMAIL_ADDRESS
SMTP_PASS=REPLACE_WITH_GMAIL_APP_PASSWORD

# ── Application ───────────────────────────────────────────────────────────────
FRONTEND_URL=https://REPLACE_WITH_VERCEL_APP_URL
CORS_ORIGINS=https://REPLACE_WITH_VERCEL_APP_URL
ENVIRONMENT=production

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_SIZE_MB=20

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=WARNING

# ── Webhooks ──────────────────────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_SECURE_RANDOM_TOKEN
